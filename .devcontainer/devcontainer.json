{
  "name": "Design Patterns Webapp",
  "image": "mcr.microsoft.com/devcontainers/python:1-3.12-bookworm",

  // Install uv, then sync the locked dependencies for the webapp.
  // Runs once at container creation. Use absolute path to uv to avoid
  // PATH-not-yet-loaded issues right after pip --user install.
  "postCreateCommand": "pip install --user uv && cd webapp && $HOME/.local/bin/uv sync",

  // Auto-start the FastAPI server on every container start (cold resume
  // included) via a self-healing detached script. The script logs to
  // /tmp/uvicorn.log; fetch with `gh codespace cp` if debugging is needed.
  "postStartCommand": "bash .devcontainer/start-server.sh",

  // Forward the FastAPI port. `visibility: private` means only your
  // authenticated GitHub account can open the forwarded URL — perfect
  // for accessing it from your phone without exposing it publicly.
  "forwardPorts": [8000],
  "portsAttributes": {
    "8000": {
      "label": "Design Patterns Webapp",
      "visibility": "private",
      "onAutoForward": "notify"
    }
  },

  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "charliermarsh.ruff"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/workspaces/${localWorkspaceFolderBasename}/webapp/.venv/bin/python"
      }
    }
  }
}
