{
  "name": "Design Patterns Webapp",
  "image": "mcr.microsoft.com/devcontainers/python:1-3.12-bookworm",

  // Install uv, then sync the locked dependencies for the webapp.
  // Runs once when the codespace is created.
  "postCreateCommand": "pip install --user uv && cd webapp && uv sync",

  // Auto-start the FastAPI server every time VS Code attaches to the
  // codespace (including resumes from idle). Object form runs the command
  // in a dedicated, persistent terminal so it doesn't block the attach.
  "postAttachCommand": {
    "server": "cd webapp && uv run uvicorn app:app --host 0.0.0.0 --port 8000 --reload"
  },

  // Forward the FastAPI port. `visibility: private` means only your
  // authenticated GitHub account can open the forwarded URL — perfect
  // for accessing it from your phone without exposing it publicly.
  "forwardPorts": [8000],
  "portsAttributes": {
    "8000": {
      "label": "Design Patterns Webapp",
      "visibility": "private",
      "onAutoForward": "notify"
    }
  },

  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "charliermarsh.ruff"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/workspaces/${localWorkspaceFolderBasename}/webapp/.venv/bin/python"
      }
    }
  }
}
